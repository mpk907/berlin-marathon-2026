# ═══════════════════════════════════════════
# Berlin Marathon Training Dashboard
# Environment Variables
# ═══════════════════════════════════════════

# WHOOP — required for live sync
# Get your refresh token from: app.whoop.com → F12 → Application → Cookies
# Look for the cognito refresh token (long string)
WHOOP_REFRESH_TOKEN=

# Vercel Blob — required for persistent storage on Vercel
# Created automatically when you add a Blob store in Vercel dashboard
# Vercel → Your Project → Storage → Create → Blob
BLOB_READ_WRITE_TOKEN=
