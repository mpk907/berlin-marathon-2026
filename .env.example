# ═══════════════════════════════════════════
# Berlin Marathon Training Dashboard
# Environment Variables
# ═══════════════════════════════════════════

# WHOOP OAuth (Phase 2 — needed for live sync)
# Register at https://developer.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=

# Database (Phase 2 — pick one)
# Option A: Turso (free SQLite)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Option B: Supabase (free Postgres)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=

# Optional: Strava for better GPS coverage
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
